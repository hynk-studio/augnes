{
  "name": "augnes-console-starter",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Starter MCP app for Augnes: Evidence & Continuity Console",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:file": "node --import tsx scripts/run-file-mode.ts dev",
    "dev:read-api": "tsx scripts/dev-read-api.ts",
    "start": "node --import tsx src/server.ts",
    "start:file": "node --import tsx scripts/run-file-mode.ts start",
    "typecheck": "tsc --noEmit",
    "inspect": "npx @modelcontextprotocol/inspector@latest --server-url http://localhost:8787/mcp --transport http",
    "smoke": "tsx scripts/smoke.ts",
    "invariants": "node --import tsx scripts/invariants.ts",
    "codex:read-brief": "tsx scripts/codex-read-brief.ts",
    "codex:record-result": "tsx scripts/codex-record-result.ts",
    "codex:record-completion": "tsx scripts/codex-record-completion.ts",
    "codex:handoff-check": "tsx scripts/codex-handoff-check.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/ext-apps": "^1.0.1",
    "@modelcontextprotocol/sdk": "^1.20.2",
    "dotenv": "^16.5.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "tsx": "^4.20.6",
    "typescript": "^5.8.3"
  }
}
