{
  "name": "augnes",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "next": "16.2.4",
    "react": "19.2.5",
    "react-dom": "19.2.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "esbuild": "0.28.1",
    "tsx": "^4.20.6",
    "typescript": "6.0.3"
  },
  "scripts": {
    "dev": "node scripts/augnes-runtime-supervisor.mjs start",
    "augnes": "node scripts/augnes-runtime-supervisor.mjs",
    "build": "node scripts/build-with-isolated-db.mjs",
    "package": "node scripts/build-distributable-package.mjs",
    "start": "next start",
    "db:init": "node scripts/db-init.mjs",
    "db:migrate": "node scripts/db-migrate.mjs",
    "db:reset": "node scripts/db-reset.mjs",
    "demo:seed": "node scripts/demo-seed.mjs",
    "augnes:codex-bootstrap": "node scripts/augnes-codex-bootstrap.mjs",
    "augnes:doctor": "node scripts/augnes-codex-doctor.mjs",
    "augnes:prepare": "node scripts/augnes-codex-prepare.mjs",
    "augnes:setup-local-demo": "node scripts/augnes-codex-local-demo-setup.mjs",
    "perspective:memory-reuse-intake": "tsx --tsconfig tsconfig.json scripts/perspective-memory-reuse-intake.mjs",
    "codex:install-augnes-reuse-hook": "node scripts/codex-install-augnes-reuse-hook.mjs",
    "codex:uninstall-augnes-reuse-hook": "node scripts/codex-uninstall-augnes-reuse-hook.mjs",
    "codex:record-completion-proof": "npm --prefix apps/augnes_apps run codex:record-completion-proof",
    "codex:read-brief": "npm --prefix apps/augnes_apps run codex:read-brief",
    "codex:next-work": "node scripts/codex-next-work.mjs",
    "codex:record-evidence": "npm --prefix apps/augnes_apps run codex:record-evidence",
    "autohunt:daily-launcher-v0-1": "tsx --tsconfig tsconfig.json scripts/autohunt-daily-launcher-v0-1.mjs",
    "typecheck": "tsc --noEmit",
    "test:operator-pure-contracts": "node --import tsx scripts/test-vnext-operator-pure-contracts-v0-1.ts",
    "test:operator-browser-fixture": "node --import tsx scripts/test-vnext-operator-browser-fixture-v0-1.ts",
    "test": "node scripts/run-canonical-test-suite.mjs unit",
    "test:integration": "node scripts/run-canonical-test-suite.mjs integration",
    "test:authority": "node scripts/run-canonical-test-suite.mjs authority",
    "test:operability": "node scripts/run-canonical-test-suite.mjs operability",
    "test:e2e": "node scripts/run-canonical-test-suite.mjs e2e"
  }
}
